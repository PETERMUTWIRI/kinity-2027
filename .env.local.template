# ==========================================
# KIKIMO FOUNDATION - ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ==========================================

# Database (Neon PostgreSQL)
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL="postgresql://user:password@your-project.neon.tech/dbname?sslmode=require"

# Neon Auth
# The auth endpoint for your Neon project
# Format: https://<project-id>.neon.tech or your custom auth domain
NEXT_PUBLIC_NEON_AUTH_URL="https://your-project.neon.tech"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Image Upload (ImgBB)
# Get API key from: https://api.imgbb.com/
NEXT_PUBLIC_IMGBB_API_KEY="your-imgbb-api-key"
IMGBB_API_KEY="your-imgbb-api-key"

# Email (Resend) - Optional
# Get API key from: https://resend.com
RESEND_API_KEY="re_your_api_key"

# Stripe (Optional - for donations)
# Get keys from: https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_key"
