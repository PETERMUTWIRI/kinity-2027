generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// NATIONAL VISION PARTY CAMPAIGN SCHEMA
// ==========================================

// News/Press Releases - Transformed from Blog Posts
model Post {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  slug          String    @unique
  subtitle      String?   @db.VarChar(500) // Secondary headline
  content       String    // HTML content from CKEditor
  excerpt       String?   @db.VarChar(500)
  category      String    @db.VarChar(100) // News, Press Release, Event Recap, Statement
  cover         String?   @db.VarChar(500) // ImgBB URL
  coverCaption  String?   @db.Text // Cover image caption
  coverPhotographer String? @db.VarChar(255) // Cover image photographer credit
  published     Boolean   @default(true)
  publishedAt   DateTime?
  featured      Boolean   @default(false) // Featured on homepage
  featuredQuote String?   @db.Text // Pull quote for highlighting
  isPressRelease Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        String?   @db.VarChar(255)
  authorTitle   String?   @db.VarChar(255) // Author's title/position
  deletedAt     DateTime? @db.Timestamp(6)
  
  // SEO Fields
  metaTitle     String?   @db.VarChar(100)
  metaDesc      String?   @db.VarChar(160)
  ogImage       String?   @db.VarChar(500)
  
  // Article Metadata
  readingTime   Int?      @default(0) // Estimated reading time in minutes
  wordCount     Int?      @default(0)
  tags          String[]  // Array of tags/keywords
  
  // Location (for local news)
  location      String?   @db.VarChar(255) // News location
  county        String?   @db.VarChar(100) // Kenyan county
  
  // Inline Images (stored as JSON for flexibility)
  inlineImages  Json?     // Array of {url, caption, photographer, align}
  
  // Relations
  comments      Comment[]

  @@unique([slug, deletedAt])
  @@index([slug])
  @@index([category])
  @@index([publishedAt])
  @@index([featured])
  @@index([deletedAt])
  @@index([published, deletedAt])
  @@index([county])
  @@index([tags])
}

// Rallies/Town Halls - Transformed from Events
model Event {
  id                Int              @id @default(autoincrement())
  title             String           @db.VarChar(255)
  slug              String           @unique
  description       String?          @db.Text // Full HTML description
  category          String           @db.VarChar(50) // Rally, Town Hall, Meeting, Fundraiser
  cover             String?          @db.VarChar(500) // ImgBB URL
  location          String           @db.VarChar(255) // County/City
  county            String?          @db.VarChar(100) // Specific Kenyan county
  venue             String?          @db.VarChar(255) // Specific venue name
  address           String?          @db.Text // Full address
  startDate         DateTime
  endDate           DateTime?
  
  // RSVP Management
  isPublic          Boolean          @default(true) // Public vs private event
  securityLevel     String           @default("open") // open, verified, invite-only
  rsvpRequired      Boolean          @default(true)
  rsvpDeadline      DateTime?
  maxAttendees      Int?             // Capacity limit
  
  // Legacy fields for backward compatibility (can be removed after migration)
  isFree            Boolean?         @default(true)
  ticketPrice       String?          @db.VarChar(50)
  ticketPriceCents  Int?
  registrationLink  String?          @db.VarChar(500)
  
  // Donation (suggested, not required)
  suggestedDonation Int?             // In cents/KES
  
  // Timestamps
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  author            String?          @db.VarChar(255)
  deletedAt         DateTime?        @db.Timestamp(6)
  
  // SEO Fields
  metaTitle         String?          @db.VarChar(100)
  metaDesc          String?          @db.VarChar(160)
  ogImage           String?          @db.VarChar(500)
  
  // Gallery
  gallery           Json?            // Array of ImgBB URLs
  
  // Relations
  registrations     RSVP[]

  @@unique([slug, deletedAt])
  @@index([slug])
  @@index([category])
  @@index([startDate])
  @@index([county])
  @@index([deletedAt])
  @@index([isPublic])
}

// User Admin (via Neon Auth)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("user") // admin, editor, volunteer_coordinator
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Video Gallery - Speeches, Rally Footage, Interviews
model Video {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String?   @db.Text
  youtubeId   String    @db.VarChar(50)
  category    String    @db.VarChar(100) // Speech, Rally, Interview, Ad, Statement
  thumbnail   String?   @db.VarChar(500) // ImgBB URL or YouTube thumbnail
  published   Boolean   @default(true)
  featured    Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]

  @@index([category])
  @@index([featured])
  @@index([order])
  @@index([published])
}

// RSVP - Event Attendance (was Registration)
model RSVP {
  id          Int      @id @default(autoincrement())
  eventId     Int
  email       String   @db.VarChar(255)
  name        String   @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  county      String?  @db.VarChar(100)
  
  // Verification
  idNumber    String?  @db.VarChar(50) // For security at verified events
  verified    Boolean  @default(false)
  
  // Status
  status      String   @default("confirmed") // confirmed, cancelled, attended, no-show
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([email])
  @@index([status])
  @@index([county])
}

// Gallery Categories - Photo Albums
model GalleryCategory {
  id                 Int       @id @default(autoincrement())
  title              String    @db.VarChar(255)
  slug               String    @unique @db.VarChar(255)
  description        String?   @db.Text
  category           String    @default("Rallies") @db.VarChar(100)
                      // Rallies, Community, Behind the Scenes, Press, County Tours
  coverImage         String?   @db.VarChar(500) // ImgBB URL
  published          Boolean   @default(true)
  order              Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime? @db.Timestamp(6)
  
  // Relations
  images             GalleryImage[]

  @@unique([slug, deletedAt], map: "GalleryCategory_slug_deletedAt_unique")
  @@index([category])
  @@index([deletedAt])
  @@index([order])
  @@index([published])
  @@index([slug])
}

// Gallery Images - Individual photos with metadata
model GalleryImage {
  id                 Int       @id @default(autoincrement())
  title              String?   @db.VarChar(255)
  url                String    @db.VarChar(500) // ImgBB URL
  
  // Album/Category relation
  albumId            Int?
  album              GalleryCategory? @relation(fields: [albumId], references: [id], onDelete: SetNull)
  
  // Metadata for filtering
  photographer       String?   @db.VarChar(255)
  location           String?   @db.VarChar(255) // Specific place
  county             String?   @db.VarChar(100) // Kenyan county
  eventDate          DateTime? // When the photo was taken
  
  // Display options
  featured           Boolean   @default(false)
  published          Boolean   @default(true)
  order              Int       @default(0)
  
  // Tags for additional filtering
  tags               String[]  // Array of tags
  
  // Timestamps
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime? @db.Timestamp(6)

  @@index([albumId])
  @@index([photographer])
  @@index([location])
  @@index([county])
  @@index([eventDate])
  @@index([tags])
  @@index([featured])
  @@index([published])
  @@index([deletedAt])
  @@index([createdAt])
}

// Comments - Supporter Engagement (MODERATED by default)
model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  author    String?  @db.VarChar(255)
  email     String?  @db.VarChar(255)
  
  // Polymorphic relations
  postId    Int?
  videoId   Int?
  
  // Moderation (CRITICAL for political site)
  approved  Boolean  @default(false) // Requires admin approval
  reviewedAt DateTime?
  reviewedBy String?  @db.VarChar(255) // Admin who approved
  
  createdAt DateTime @default(now())
  
  // Relations
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  video     Video?   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([videoId])
  @@index([approved])
  @@index([createdAt])
}

// ==========================================
// NEW MODELS FOR POLITICAL CAMPAIGN
// ==========================================

// Volunteers - Ground Game Management
model Volunteer {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  email       String   @unique @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  
  // Location
  county      String   @db.VarChar(100) // Kenyan county for organizing
  constituency String? @db.VarChar(100)
  ward        String?  @db.VarChar(100)
  
  // Role & Skills
  role        String   @db.VarChar(100) 
    // Canvassing, Event Staff, Digital, Phone Banking, Driver, Security, Medical
  skills      String?  @db.Text // Additional skills/qualifications
  availability String? @db.Text // Weekends, Weekdays, Evenings
  
  // Message & Status
  message     String?  @db.Text // Why they want to volunteer
  status      String   @default("pending") // pending, active, inactive, rejected
  
  // Admin notes
  notes       String?  @db.Text
  assignedTo  String?  @db.VarChar(255) // Staff member managing this volunteer
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([county])
  @@index([status])
  @@index([role])
  @@index([createdAt])
}

// Endorsements - Social Proof
model Endorsement {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  title       String   @db.VarChar(255) // "Community Leader", "Business Owner", "Youth Leader"
  organization String? @db.VarChar(255) // Organization they represent
  quote       String   @db.Text // Endorsement quote
  photo       String?  @db.VarChar(500) // ImgBB URL
  
  // Location
  county      String   @db.VarChar(100)
  
  // Display
  featured    Boolean  @default(false) // Show on homepage
  order       Int      @default(0)
  published   Boolean  @default(false) // Admin approval required
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([county])
  @@index([featured])
  @@index([published])
  @@index([order])
}

// Manifesto Pillars - Policy Positions
model ManifestoPillar {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255) // "Economic Transformation", "Zero Corruption"
  subtitle    String?  @db.VarChar(255) // Short tagline
  icon        String   @db.VarChar(100) // Lucide icon name
  
  // Content
  summary     String   @db.Text // Short paragraph for cards
  details     String   @db.Text // Full policy description (CKEditor HTML)
  keyPoints   Json?    // Array of bullet points ["Point 1", "Point 2"]
  
  // Display
  order       Int      // Display order
  color       String   @db.VarChar(50) // Pillar accent color (blue, red, purple, etc.)
  published   Boolean  @default(false)
  featured    Boolean  @default(false) // Show on homepage
  
  // Media
  image       String?  @db.VarChar(500) // ImgBB URL
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([published])
  @@index([featured])
}

// Donation Tiers - Impact-based Giving (was Product)
model DonationTier {
  id              Int        @id @default(autoincrement())
  title           String     @db.VarChar(255) // "Supporter", "Patriot", "Champion"
  description     String?    @db.Text
  
  // Impact messaging
  impactDescription String   @db.Text // "Your 1,000 KES provides 10 rally banners"
  impactMetric    String?    @db.VarChar(255) // "10 banners", "5 meals for volunteers"
  
  // Pricing
  amountKES       Int        // Amount in Kenyan Shillings
  amountUSD       Int?       // Amount in USD for international donors
  
  // Display
  category        String     @db.VarChar(100) // Individual, Corporate, International
  image           String?    @db.VarChar(500) // ImgBB URL
  published       Boolean    @default(true)
  featured        Boolean    @default(false)
  order           Int        @default(0)
  
  // Stripe integration (commented for now)
  // stripeProductId String?   @db.VarChar(255)
  // stripePriceId   String?   @db.VarChar(255)
  
  // Timestamps
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  // Relations
  contributions   Contribution[]

  @@index([category])
  @@index([published])
  @@index([order])
  @@index([featured])
}

// Contributions - Donation Records (was Purchase)
model Contribution {
  id              String   @id @default(uuid())
  
  // Donor info
  donorName       String   @db.VarChar(255)
  donorEmail      String   @db.VarChar(255)
  donorPhone      String?  @db.VarChar(50)
  
  // Location
  county          String?  @db.VarChar(100)
  country         String   @default("Kenya") @db.VarChar(100)
  
  // Donation details
  donationTierId  Int
  amount          Int      // In smallest currency unit (cents/KES)
  currency        String   @default("KES") @db.VarChar(3)
  isAnonymous     Boolean  @default(false)
  message         String?  @db.Text // Encouragement message
  
  // Payment tracking (M-Pesa / Stripe)
  paymentMethod   String   @db.VarChar(50) // MPesa, Card, Bank, Crypto, Cash
  transactionId   String?  @db.VarChar(255) // M-Pesa code or Stripe ID
  phoneNumber     String?  @db.VarChar(50) // For M-Pesa
  
  // Compliance
  nationality     String?  @db.VarChar(100) // "Kenyan" / "Other" (foreign donation rules)
  idNumber        String?  @db.VarChar(50) // For large donations compliance
  
  // Status
  status          String   @default("pending") // pending, completed, failed, refunded
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  donationTier    DonationTier @relation(fields: [donationTierId], references: [id])

  @@index([donationTierId])
  @@index([status])
  @@index([createdAt])
  @@index([county])
  @@index([transactionId])
}

// Media Kit Assets - For Press
model MediaAsset {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  type        String   @db.VarChar(50) // Photo, Video, Document, Logo, Bio
  category    String   @db.VarChar(100) // Press Kit, Headshots, Rally Photos, B-Roll
  url         String   @db.VarChar(500) // Download URL (ImgBB or other)
  fileSize    String?  @db.VarChar(50)
  dimensions  String?  @db.VarChar(50) // For images
  downloadCount Int    @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([published])
}

// Campaign Statistics (for dashboard)
model CampaignStat {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  
  // Metrics
  volunteerCount  Int      @default(0)
  totalContributions Int   @default(0)
  totalContributionAmount Int @default(0)
  subscriberCount Int      @default(0)
  eventRSVPCount  Int      @default(0)
  websiteVisits   Int      @default(0)
  
  // County breakdown (stored as JSON)
  countyBreakdown Json?
  
  @@index([date])
}

// Newsletter Subscribers - Digital Campaign Engine
model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique @db.VarChar(255)
  name        String?  @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  county      String?  @db.VarChar(100)
  subscribed  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subscribed])
  @@index([county])
  @@index([createdAt])
}
